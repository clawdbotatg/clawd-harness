[Unit]
Description=clawd fleet relay (mobile <-> machines hub)
After=network.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/clawd-fleet
EnvironmentFile=/home/ubuntu/clawd-fleet/fleet.env
ExecStart=/usr/bin/python3 /home/ubuntu/clawd-fleet/relay.py
Restart=always
RestartSec=2

[Install]
WantedBy=multi-user.target
