# Copy to fleet.env next to relay.py / worker.py (gitignored). The systemd units
# load this via EnvironmentFile. The relay also reads .clawd-fleet.token directly
# if FLEET_TOKEN is unset.
FLEET_BIND=127.0.0.1          # relay bind addr (127.0.0.1 = front it with nginx/TLS)
FLEET_PORT=8788               # relay port
FLEET_RELAY=ws://127.0.0.1:8788   # worker → relay URL (use wss://<domain> off-box)

# Auth: two separate secrets (generate each: python3 -c "import secrets;print(secrets.token_urlsafe(24))").
# The MOBILE token is the user's access credential (rides in the page URL). The
# WORKER token authorizes a machine to register — keep it separate so a leaked
# mobile URL can't impersonate a worker. Both fall back to FLEET_TOKEN (or
# .clawd-fleet.token) if unset, for simple single-token setups.
FLEET_MOBILE_TOKEN=changeme-mobile
FLEET_WORKER_TOKEN=changeme-worker
# FLEET_TOKEN=changeme        # single-token fallback (used if the two above are unset)

# Worker allowlist: only these machine ids may register (comma-separated). Empty
# = allow any machine that presents the worker token. Set it in production.
FLEET_WORKER_ALLOW=zkllmapi-box,austin-laptop

# The `exec` shell handler is OFF by default (it's a diagnostic, not the product —
# the harness proxy is). Set to 1 ONLY on a machine where you want raw remote shell.
# FLEET_ALLOW_EXEC=1

# Harness-proxy worker only (the machine that runs a clawd-harness). The worker
# bridges to its LOCAL harness; these point at it. HARNESS_TOKEN auto-discovers
# from .clawd-harness.token if unset, so usually you only need these off-box.
HARNESS_WS=ws://127.0.0.1:8787    # local harness WebSocket base URL
# HARNESS_TOKEN=                  # harness token (default: read from .clawd-harness.token)
