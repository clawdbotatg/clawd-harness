# runtime / local state — never commit (comments on their own lines!)

# auth secret
.clawd-harness.token
# local secrets / config (BANKR_API_KEY etc.) — loaded by server.py at boot
.clawd-harness.env
# local session id (legacy single-session) + multi-session registry
.clawd-harness.session
.clawd-harness.sessions.json
# generated; embed the token in curl URLs (one per session)
.clawd-harness.hooks.json
.clawd-harness.hooks.*.json
# pasted/uploaded images (may contain anything)
.clawd-harness-uploads/
# projects = cloned/created git repos we drive — never enter the harness repo
projects/

# fleet/ runtime state (relay/worker layer — see fleet/CLAUDE.md)
fleet/.clawd-fleet.token
fleet/.clawd-fleet.machine
fleet/.clawd-fleet.passkeys.json
fleet/fleet.env
fleet/*.log

# os / editor cruft
.DS_Store
__pycache__/
*.pyc
